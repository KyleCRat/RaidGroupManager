-- 4 rows of 2 groups side by side, relative anchoring to avoid subpixel gaps
function addon:CreateGrid(parent)
    local colWidth = SLOT_WIDTH + 10
    local headers = {}
    local lastSlotInCol = { nil, nil } -- track bottom slot per column for group gap anchoring

    for g = 1, 8 do
        local col = (g - 1) % 2
        local colIndex = col + 1

        -- Group header — small, centered, faded
        local header = parent:CreateFontString(nil, "ARTWORK")
        header:SetFont(FONT, 12, "OUTLINE")
        header:SetText("Group " .. g)
        header:SetTextColor(0.5, 0.5, 0.5, 0.7)
        headers[g] = header

        local groupOffsetX = col * (colWidth + 4)

        if g <= 2 then
            -- First row of groups: anchor to parent top
            local headerCenterX = groupOffsetX + (SLOT_WIDTH / 2)
            header:SetPoint("TOP", parent, "TOPLEFT", headerCenterX, 0)
        else
            -- Subsequent rows: anchor below the last slot in this column
            local prevLastSlot = lastSlotInCol[colIndex]
            local headerCenterX = SLOT_WIDTH / 2
            header:SetPoint("TOP", prevLastSlot, "BOTTOMLEFT", headerCenterX, -GROUP_GAP)
        end

        -- Slots
        local prevSlot = nil
        for p = 1, 5 do
            local slotIndex = (g - 1) * 5 + p
            local slot = CreateSlotFrame(parent, slotIndex)

            if p == 1 then
                -- First slot: anchor below header
                slot:SetPoint("TOPLEFT", parent, "TOPLEFT", groupOffsetX, 0)
                slot:SetPoint("TOPLEFT", header, "BOTTOM", -(SLOT_WIDTH / 2), 0)
            else
                -- Subsequent slots: anchor below previous slot
                slot:SetPoint("TOPLEFT", prevSlot, "BOTTOMLEFT", 0, -SLOT_GAP)
            end

            prevSlot = slot
            self.slots[slotIndex] = slot
        end

        lastSlotInCol[colIndex] = prevSlot
    end
end
